{
  "name": "@yngvenot-platform/frontend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postbuild": "echo 'Build complete.'",
    "prebuild": "echo 'WASM assets should be built directly into /public/wasm. Run `make build-wasm` and then `npm run wasm:lint-fix` if needed.'",
